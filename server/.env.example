# ── Server ──────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-me-in-prod

# ── Mock web2 login ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ── KERIA / Signify agent ───────────────────────────────
KERIA_ENABLED=true
KERIA_BOOT_URL=http://localhost:3903
KERIA_CONNECT_URL=http://localhost:3901
# 21-char passcode for the platform agent. Generate once and keep stable so the
# same AID/registry is reused across restarts. Leave blank to auto-generate.
SIGNIFY_BRAN=
AGENT_NAME=VeridianPoc

# ── Credential schema (issuance chunk) ──────────────────
# Foundation Employee schema (attributes: email, firstName, lastName).
EXPECTED_SCHEMA_SAID=EL9oOWU_7zQn_rD--Xsgi3giCWnFDaNvFMUGTOZx1ARO
# Leave SCHEMA_OOBI_URL empty for the connection chunk (no schema server yet).
# When the schema server is running, set it to a URL reachable from inside the
# KERIA container, e.g. http://cred-issuance:3001/oobi/<said>
SCHEMA_OOBI_URL=
